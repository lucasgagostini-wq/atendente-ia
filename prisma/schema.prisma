generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LeadStatus {
  NEW
  QUALIFIED
  NEGOTIATION
  CONVERTED
  LOST
}

enum FunnelStage {
  COLD
  WARM
  HOT
  CHECKOUT
  CUSTOMER
}

enum OperationStage {
  PAID_ORDER
  PRODUCTION
  READY_TO_SEND
  SENT
  PIX_RECOVERY
  SUPPORT
}

enum ConversationStatus {
  OPEN
  ARCHIVED
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageRole {
  LEAD
  ASSISTANT
  HUMAN
  SYSTEM
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
}

enum OutboundMessageJobStatus {
  PENDING
  PROCESSING
  SENT
  ERROR
}

enum ProspectingJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum ProfileStatus {
  ACTIVE
  PAUSED
  AWAITING_WHATSAPP
  DISCONNECTED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Profile {
  id                  String        @id @default(cuid())
  name                String
  slug                String        @unique
  description         String?
  status              ProfileStatus @default(ACTIVE)
  aiEnabled           Boolean       @default(false)
  whatsappNumber      String?
  whatsappSessionName String?
  pixKey              String?
  pixName             String?
  pixBank             String?
  promptConfig        Json?
  settings            Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  leads               Lead[]
  outboundMessageJobs OutboundMessageJob[]
  prompts             Prompt[]

  @@index([status])
}

model Lead {
  id             String         @id @default(cuid())
  profileId       String?
  name           String?
  phone          String
  status         LeadStatus     @default(NEW)
  funnelStage    FunnelStage    @default(COLD)
  operationStage OperationStage?
  source         String?
  aiEnabled      Boolean        @default(true)
  humanTakeover  Boolean        @default(false)
  summary        String?
  interest       String?
  objections     Json?
  lastMessage    String?
  lastMessageAt  DateTime?
  // Estado persistente de mídia/foto de serviço. Substitui o marcador frágil
  // [FOTO_RECEBIDA] no summary: depois que o lead manda uma foto, esse estado
  // sobrevive à janela curta de histórico e é consultado pelos gates e pela
  // safety final para nunca mais pedir a foto.
  hasReceivedImage Boolean      @default(false)
  lastImageAt      DateTime?
  imageCount       Int          @default(0)
  // Marca de "mídia a caminho": o bridge sinaliza MEDIA_PENDING antes de baixar
  // a imagem, para o webhook estender a janela de silêncio e juntar texto+imagem
  // do mesmo burst no mesmo batch.
  pendingMediaAt   DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  profile        Profile?       @relation(fields: [profileId], references: [id], onDelete: SetNull)
  conversations  Conversation[]
  messages       Message[]
  leadTags       LeadTag[]
  outboundMessageJobs OutboundMessageJob[]
  prospectingEntries ProspectingLead[] @relation("ImportedProspectingLead")

  @@unique([profileId, phone])
  @@index([profileId, lastMessageAt])
  @@index([profileId, operationStage, lastMessageAt])
}

model Conversation {
  id        String             @id @default(cuid())
  leadId    String
  status    ConversationStatus @default(OPEN)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  lead      Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages  Message[]
  outboundMessageJobs OutboundMessageJob[]
}

model Message {
  id                String           @id @default(cuid())
  conversationId    String
  leadId            String
  direction         MessageDirection
  role              MessageRole
  type              MessageType      @default(TEXT)
  content           String
  // ID da mensagem original no WhatsApp. Usado para deduplicação O(1) via índice,
  // evitando varredura JSON na tabela inteira a cada mensagem recebida.
  whatsappMessageId String?
  metadata          Json?
  createdAt         DateTime         @default(now())
  conversation      Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lead              Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([whatsappMessageId])
}

model OutboundMessageJob {
  id                String                   @id @default(cuid())
  profileId         String
  leadId            String
  conversationId    String
  phone             String
  text              String
  status            OutboundMessageJobStatus @default(PENDING)
  transport         String                   @default("BAILEYS_BRIDGE_OUTBOX")
  attempts          Int                      @default(0)
  lastAttemptAt     DateTime?
  sentAt            DateTime?
  errorMessage      String?
  whatsappMessageId String?
  providerPayload   Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  profile           Profile                  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  lead              Lead                     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  conversation      Conversation             @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([profileId, status, createdAt])
  @@index([conversationId, status, createdAt])
  @@index([leadId, status, createdAt])
}

model Prompt {
  id               String   @id @default(cuid())
  profileId        String?
  name             String   @default("Prompt Principal")
  personality      String
  tone             String
  goal             String
  rules            String
  faq              String
  objections       String
  offer            String
  checkoutUrl      String?
  transferTriggers String
  cta              String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  profile          Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([profileId, isActive])
}

model Automation {
  id           String   @id @default(cuid())
  name         String
  trigger      String
  message      String
  delayMinutes Int
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  color    String
  createdAt DateTime @default(now())
  leadTags LeadTag[]
}

model LeadTag {
  leadId String
  tagId  String
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
}

model Settings {
  id                    String   @id @default("default")
  evolutionApiUrl       String?
  evolutionApiKey       String?
  evolutionInstanceName String?
  webhookUrl            String?
  openRouterApiKey      String?
  openRouterModel       String   @default("openai/gpt-oss-20b:free")
  apifyApiToken         String?
  prospectorMapsActorId String   @default("compass/crawler-google-places")
  temperature           Float    @default(0.6)
  minDelaySeconds       Int      @default(2)
  maxDelaySeconds       Int      @default(8)
  safeMode              Boolean  @default(true)
  defaultCheckoutUrl    String?
  // Pausa global da IA — quando true, o webhook salva mensagens mas não responde automaticamente
  aiPaused              Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Log {
  id        String   @id @default(cuid())
  type      String
  message   String
  payload   Json?
  createdAt DateTime @default(now())
}

model ProspectingJob {
  id           String             @id @default(cuid())
  query        String
  maxResults   Int
  source       String             @default("google_maps")
  status       ProspectingJobStatus @default(QUEUED)
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  resultsCount Int                @default(0)
  importedCount Int               @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  leads        ProspectingLead[]
}

model ProspectingLead {
  id               String   @id @default(cuid())
  jobId            String
  source           String   @default("google_maps")
  companyName      String
  phone            String?
  rating           Float?
  reviewsCount     Int?
  address          String?
  website          String?
  mapsUrl          String?
  placeId          String?
  businessCategory String?
  imported         Boolean  @default(false)
  importedLeadId   String?
  rawPayload       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  job              ProspectingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  importedLead     Lead? @relation("ImportedProspectingLead", fields: [importedLeadId], references: [id], onDelete: SetNull)

  @@index([jobId])
  @@index([phone])
  @@index([placeId])
}
