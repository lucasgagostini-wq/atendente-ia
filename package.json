{
  "name": "atendente-ia",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "check": "npm run lint && npm run build",
    "test:ai-safety": "tsx scripts/test-ai-safety.ts",
    "test:typing-delay": "tsx scripts/test-typing-delay.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "setup": "node scripts/setup.mjs",
    "bridge": "node --env-file=.env scripts/baileys-bridge.mjs",
    "bridge:baileys": "node --env-file=.env scripts/baileys-bridge.mjs",
    "bridge:local": "node --env-file=.env scripts/bridge-local.mjs",
    "start:local": "concurrently --names \"APP,WHATSAPP\" --prefix-colors \"cyan,green\" \"npm run dev\" \"npm run bridge:local\"",
    "whatsapp": "node scripts/start-whatsapp.mjs",
    "ai:check": "tsx scripts/ai-check.ts",
    "test:webhook-logic": "tsx scripts/test-webhook-logic.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:public": "playwright test --project=smoke-public",
    "setup:e2e-user": "tsx scripts/setup-e2e-user.ts",
    "prune-logs": "tsx scripts/prune-logs.ts"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-query": "^5.100.14",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "apify-client": "^2.23.3",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next": "^14.2.33",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^10.0.3",
    "eslint": "^8",
    "eslint-config-next": "^14.2.33",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
