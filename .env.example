# ──────────────────────────────────────────────────────────────
# Atendente IA — variáveis de ambiente (exemplo)
# Copie para .env e preencha. NUNCA versione o .env real.
# ──────────────────────────────────────────────────────────────

# ── Banco de dados (Supabase / Postgres) ──────────────────────
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Autenticação (painel admin) ───────────────────────────────
# OBRIGATÓRIO em produção. Gere um valor forte: `openssl rand -base64 48`
# Em produção, sem este valor, a sessão é assinada com um segredo DERIVADO do
# banco (DATABASE_URL) — nunca com a constante pública "dev-secret". Ainda
# assim, defina um valor dedicado aqui/na Vercel.
ADMIN_SESSION_SECRET=
# Aliases aceitos caso ADMIN_SESSION_SECRET não esteja definido (ordem: JWT_SECRET, depois NEXTAUTH_SECRET).
JWT_SECRET=
NEXTAUTH_SECRET=
# Token usado uma única vez para criar o admin em /setup-admin.
ADMIN_SETUP_TOKEN=

# ── IA (OpenRouter) ───────────────────────────────────────────
OPENROUTER_API_KEY=
# Modelo principal (aceita PRIMARY_AI_MODEL ou OPENROUTER_DEFAULT_MODEL)
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-chat
PRIMARY_AI_MODEL=
# Modelo de fallback (aceita FALLBACK_AI_MODEL ou OPENROUTER_FALLBACK_MODEL)
OPENROUTER_FALLBACK_MODEL=
FALLBACK_AI_MODEL=
# Modelo com visão, usado para ler comprovante de pagamento (imagem)
OPENROUTER_VISION_MODEL=
VISION_AI_MODEL=
# Timeout e retries da chamada de IA
AI_TIMEOUT_MS=20000
AI_MAX_RETRIES=1

# ── WhatsApp: Bridge Baileys (local) ──────────────────────────
BAILEYS_BRIDGE_PORT=8080
BAILEYS_BRIDGE_API_KEY=troque-essa-chave
BAILEYS_BRIDGE_INSTANCE_NAME=atendente-ia
# URL pública do app que recebe o webhook (em produção, o domínio Vercel)
BAILEYS_BRIDGE_WEBHOOK_URL=
# Conecta sozinho na inicialização usando a sessão salva em .baileys/
BAILEYS_BRIDGE_AUTOSTART=true
# Reconecta automaticamente se a conexão cair
BAILEYS_AUTO_RECONNECT=true
# Diretório da sessão (padrão: .baileys/<instance>)
BAILEYS_AUTH_DIR=

# ── WhatsApp: Evolution API (opcional / envio manual) ─────────
# Usado para envio manual, disparos e status server-side.
# Em produção precisa ser uma URL pública (ex.: túnel/host do bridge).
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=

# ── Ritmo de digitação ("typing") ─────────────────────────────
# Todos em milissegundos. Deixe em branco para usar os padrões do código.
MIN_TYPING_DELAY_MS=1500
SHORT_TYPING_DELAY_MS=3000
MEDIUM_TYPING_DELAY_MS=5000
LONG_TYPING_DELAY_MS=7000
MAX_TYPING_DELAY_MS=15000
TYPING_BUFFER_MS=1000
# Cobertura inicial de "digitando" enquanto a IA processa (bridge)
TYPING_COVER_MS=12000
# Resposta da IA: timeout e mínimo para o modo "resposta rápida"
AI_RESPONSE_TIMEOUT_MS=12000
AI_FAST_RESPONSE_MIN_DELAY_MS=1500
# Debounce de mensagens recebidas em sequência
INCOMING_MESSAGE_DEBOUNCE_MS=2500

# ── Prospecção (Apify / Google Maps) ──────────────────────────
APIFY_API_TOKEN=
PROSPECTOR_MAPS_ACTOR_ID=compass/crawler-google-places

# ── Segurança: autenticação do bridge Baileys ─────────────────
# Segredo compartilhado entre bridge e servidor para validar o webhook.
# Gere com: openssl rand -hex 32
# Defina em AMBOS os lados simultaneamente; sem isso, o bridge não consegue
# chamar o webhook em produção. Deixe vazio para modo legado (sem validação).
WEBHOOK_SECRET=

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# URL de checkout padrão usada pelo seed para popular o campo do prompt
DEFAULT_CHECKOUT_URL=
